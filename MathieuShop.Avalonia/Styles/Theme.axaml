<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <Color x:Key="ShellBgColor">#FFFFFFFF</Color>
    <Color x:Key="PanelBgColor">#FFFFFFFF</Color>
    <Color x:Key="PanelAltColor">#FFF8F8F8</Color>
    <Color x:Key="PrimaryColor">#FFF2F2F2</Color>
    <Color x:Key="SecondaryColor">#FFF7F7F7</Color>
    <Color x:Key="AccentColor">#FFE7E7E7</Color>
    <Color x:Key="InkColor">#FF101010</Color>
    <Color x:Key="MutedColor">#FF5E5E5E</Color>
    <Color x:Key="BorderColor">#FF7F7F7F</Color>

    <SolidColorBrush x:Key="ShellBgBrush" Color="{StaticResource ShellBgColor}" />
    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBgColor}" />
    <SolidColorBrush x:Key="PanelAltBrush" Color="{StaticResource PanelAltColor}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource ShellBgBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="FontFamily" Value="Segoe UI" />
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.panel.alt">
    <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
  </Style>

  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
  </Style>

  <Style Selector="TextBlock.subtitle">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="MinHeight" Value="30" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
  </Style>

  <Style Selector="Button.nav">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="Button.window">
    <Setter Property="MinHeight" Value="30" />
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="MinWidth" Value="88" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.tab">
    <Setter Property="Padding" Value="18,6" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="Margin" Value="0,0,4,0" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="CaretBrush" Value="{StaticResource InkBrush}" />
  </Style>

  <Style Selector="TextBox:pointerover, TextBox:focus">
    <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="MinHeight" Value="28" />
  </Style>

  <Style Selector="ComboBox:pointerover, ComboBox:focus">
    <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
  </Style>

  <Style Selector="ComboBoxItem:selected">
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="ListBoxItem:pointerover">
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBoxItem /template/ Border#SelectionIndicator">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
</Styles>
